{
  // TEST CASE 20: Multi-Constellation What-If Analysis
  //
  // Same environment as TC18: 100 background satellites across 25 altitude bands
  // (300–2500 km) plus a single Red target at 700 km orbiting CCW.
  //
  // 10 what-if scenarios explore different starting positions for a Yellow candidate
  // at the same 700 km altitude:
  //   A–H  CW counter-orbit starting at angles that yield crashes at ~50, 200, 400,
  //         600, 800, 1000, 1200, 1350 s respectively.
  //   I    CW counter-orbit, same placement as TC18 — crash expected at ~1479 s.
  //   J    CCW co-orbit, 90° ahead of Red — same period, always 90° apart, NO crash.
  //
  // Orbital parameters (700 km):  r=7,071,000 m  v=7,508 m/s  ω≈0.001062 rad/s
  // Collision time formula (CW candidate at angle α): t ≈ α / (2ω)
  // Each step = 1 s (SatelliteSetup timeStep).

  "name": "Multi-constellation: what-if analysis (10 scenarios)",
  "outerSetup": "WhatIfRunSetup",
  "innerSetup": "SatelliteSetup",
  "description": "What-if analysis over 10 candidate starting positions at 700 km. Eight counter-orbiting (CW) placements produce crashes at progressively later times (steps 50–1479). One CCW co-orbital placement at 90° offset never crosses the target path. One CW placement exactly mirrors TC18. Each inner simulation stops as soon as a collision is detected. A consolidated summary is printed at the end.",
  "headerLines": [
    "TEST CASE 20: Multi-Constellation What-If Analysis",
    "Background : 100 sats, 25 bands (300–2500 km), inclinations 0°–165°",
    "Target     : Red  at (7,071,000, 0, 0) m  |  v=(0,+7508,0) m/s  CCW  700 km",
    "Scenarios  : 8 × CW crash (steps 50–1479)  +  1 × TC18 clone  +  1 × safe CCW"
  ],

  // =========================================================================
  // BASE ENTITIES — spawned in every inner simulation
