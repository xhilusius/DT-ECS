{
  "testCases": [
    // ===== TEST CASE 1 =====
    {
      "name": "Single entity: gravity and positioning",
      "configurationFile": "DefaultSetup.json",
      "description": "Single entity falling under gravity with terminal velocity",
      "headerLines": [
        "TEST CASE 1: Single Entity - Gravity & Positioning"
      ],
      "steps": [
        {
          "step": 0,
          "actions": [
            { "type": "spawn", "entity": "Ball_GravityOnly", "properties": { "Position": [0, 50, 0], "Color": "Red", "Mass": 1.0, "Radius": 0.2 } }
          ]
        }
      ]
    },

    // ===== TEST CASE 2 =====
    {
      "name": "Three entities: mass and radius variations",
      "configurationFile": "DefaultSetup.json",
      "description": "Three entities with different mass/radius combinations showing terminal velocity differences",
      "headerLines": [
        "TEST CASE 2: Three Entities - Mass & Radius Variations",
        "E1 & E2: same mass, different radius",
        "E2 & E3: same radius, different mass"
      ],
      "steps": [
        {
          "step": 0,
          "actions": [
            { "type": "spawn", "entity": "Ball_GravityDrag", "properties": { "Position": [-3, 50, 0], "Color": "Blue", "Mass": 0.5, "Radius": 0.4 } },
            { "type": "spawn", "entity": "Ball_GravityDrag", "properties": { "Position": [0, 50, 0], "Color": "Cyan", "Mass": 0.5, "Radius": 0.6 } },
            { "type": "spawn", "entity": "Ball_GravityDrag", "properties": { "Position": [3, 50, 0], "Color": "Yellow", "Mass": 2.0, "Radius": 0.6 } }
          ]
        }
      ]
    },

    // ===== TEST CASE 3 =====
    {
      "name": "Two entities: one complete, one incomplete",
      "configurationFile": "DefaultSetup.json",
      "description": "Two entities: one with all properties (simulates), one missing Mass (no behavior)",
      "headerLines": [
        "TEST CASE 3: Two Entities - Complete vs Incomplete",
        "E1: has all required properties (will simulate)",
        "E2: missing Mass (will NOT simulate)"
      ],
      "steps": [
        {
          "step": 0,
          "actions": [
            { "type": "spawn", "entity": "Ball_GravityDrag", "properties": { "Position": [-2, 50, 0], "Color": "Cyan", "Mass": 1.0, "Radius": 0.2 } },
            { "type": "spawn", "entity": "Ball_NoMass", "properties": { "Position": [2, 50, 0], "Color": "Magenta", "Radius": 0.2 } }
          ]
        },
        {
          "step": 50,
          "actions": [
            { "type": "remove", "entity": "Ball_NoMass", "properties": { "EntityId": 1 } }
          ]
        }
      ]
    },

    // ===== TEST CASE 4 =====
    {
      "name": "Magnetism: metallic vs non-metallic entities",
      "configurationFile": "DefaultSetup.json",
      "description": "Two entities: one metallic (affected by magnetic field), one non-metallic (gravity only)",
      "headerLines": [
        "TEST CASE 4: Magnetism - Metallic vs Non-Metallic",
        "Metal ball: gravity + magnetic force (upward)",
        "Plastic ball: gravity only"
      ],
      "steps": [
        {
          "step": 0,
          "actions": [
            { "type": "spawn", "entity": "Ball_GravityDragMagnetism", "properties": { "Position": [-2, 50, 0], "Color": "Silver", "Mass": 1.0, "Radius": 0.2 } },
            { "type": "spawn", "entity": "Ball_GravityDrag", "properties": { "Position": [2, 50, 0], "Color": "Orange", "Mass": 1.0, "Radius": 0.2 } }
          ]
        }
      ]
    },

    // ===== TEST CASE 5 =====
    {
      "name": "Wind effect: large radius vs small radius",
      "configurationFile": "DefaultSetup.json",
      "description": "Two entities with same mass: one with large radius (affected by wind), one with small radius (minimal wind effect)",
      "headerLines": [
        "TEST CASE 5: Wind Effect - Large vs Small Radius",
        "Large ball: gravity + wind (large cross-section)",
        "Small ball: gravity + minimal wind (small cross-section)"
      ],
      "steps": [
        {
          "step": 0,
          "actions": [
            { "type": "spawn", "entity": "Ball_GravityDragWind", "properties": { "Position": [-2, 50, 0], "Color": "DeepSkyBlue", "Mass": 1.0, "Radius": 1.0 } },
            { "type": "spawn", "entity": "Ball_GravityDragWind", "properties": { "Position": [2, 50, 0], "Color": "Turquoise", "Mass": 1.0, "Radius": 0.5 } }
          ]
        }
      ]
    },

    // ===== TEST CASE 6 =====
    {
      "name": "Combined forces: gravity only, gravity+magnetism, gravity+wind, gravity+magnetism+wind",
      "configurationFile": "DefaultSetup.json",
      "description": "Four entities with identical size/mass but different force combinations: gravity-only, gravity+magnetism, gravity+wind, gravity+magnetism+wind",
      "headerLines": [
        "TEST CASE 6: Combined Forces - Force Composition",
        "Entity 1: gravity only (downward)",
        "Entity 2: gravity + magnetism (upward magnetic force)",
        "Entity 3: gravity + wind (horizontal wind push)",
        "Entity 4: gravity + magnetism + wind (all forces)"
      ],
      "steps": [
        {
          "step": 0,
          "actions": [
            { "type": "spawn", "entity": "Ball_GravityDrag", "properties": { "Position": [-4, 50, 0], "Color": "Red", "Mass": 1.0, "Radius": 0.3 } },
            { "type": "spawn", "entity": "Ball_GravityDragMagnetism", "properties": { "Position": [-1, 50, 0], "Color": "Gold", "Mass": 1.0, "Radius": 0.3 } },
            { "type": "spawn", "entity": "Ball_GravityDragWind", "properties": { "Position": [1, 50, 0], "Color": "Cyan", "Mass": 1.0, "Radius": 0.3 } },
            { "type": "spawn", "entity": "Ball_GravityDragMagnetismWind", "properties": { "Position": [4, 50, 0], "Color": "Lime", "Mass": 1.0, "Radius": 0.3 } }
          ]
        }
      ]
    },

    // ===== TEST CASE 7 =====
    {
      "name": "Single entity + Earth: N-body gravity",
      "configurationFile": "NBodySetup.json",
      "description": "Single entity falling under N-body gravitational attraction from Earth",
      "headerLines": [
        "TEST CASE 7: Single Entity + Earth - N-Body Gravity"
      ],
      "steps": [
        {
          "step": 0,
          "actions": [
            { "type": "spawn", "entity": "Earth" },
            { "type": "spawn", "entity": "EarthSurface" },
            { "type": "spawn", "entity": "Ball_GravityOnly", "properties": { "Position": [0, 6.37105e6, 0], "Color": "Red", "Mass": 1.0, "Radius": 0.2 } }
          ]
        }
      ]
    },

    // ===== TEST CASE 8 =====
    {
      "name": "Three entities + Earth: N-body mass and radius variations",
      "configurationFile": "NBodySetup.json",
      "description": "Three entities with different mass/radius combinations under N-body gravitational attraction from Earth",
      "headerLines": [
        "TEST CASE 8: Three Entities + Earth - N-Body Mass & Radius Variations",
        "E1 & E2: same mass, different radius",
        "E2 & E3: same radius, different mass"
      ],
      "steps": [
        {
          "step": 0,
          "actions": [
            { "type": "spawn", "entity": "Earth" },
            { "type": "spawn", "entity": "EarthSurface" },
            { "type": "spawn", "entity": "Ball_GravityDrag", "properties": { "Position": [-3, 6.37105e6, 0], "Color": "Blue", "Mass": 0.5, "Radius": 0.4 } },
            { "type": "spawn", "entity": "Ball_GravityDrag", "properties": { "Position": [0, 6.37105e6, 0], "Color": "Lime", "Mass": 0.5, "Radius": 0.6 } },
            { "type": "spawn", "entity": "Ball_GravityDrag", "properties": { "Position": [3, 6.37105e6, 0], "Color": "Yellow", "Mass": 2.0, "Radius": 0.6 } }
          ]
        }
      ]
    },

    // ===== TEST CASE 9 =====
    {
      "name": "Two entities + Earth: one complete, one incomplete",
      "configurationFile": "NBodySetup.json",
      "description": "Two entities under N-body gravity: one with all properties (simulates), one missing Mass (no behavior)",
      "headerLines": [
        "TEST CASE 9: Two Entities + Earth - Complete vs Incomplete",
        "E1: has all required properties (will simulate)",
        "E2: missing Mass (will NOT simulate)"
      ],
      "steps": [
        {
          "step": 0,
          "actions": [
            { "type": "spawn", "entity": "Earth" },
            { "type": "spawn", "entity": "EarthSurface" },
            { "type": "spawn", "entity": "Ball_GravityDrag", "properties": { "Position": [-2, 6.37105e6, 0], "Color": "Cyan", "Mass": 1.0, "Radius": 0.2 } },
            { "type": "spawn", "entity": "Ball_NoMass", "properties": { "Position": [2, 6.37105e6, 0], "Color": "Magenta", "Radius": 0.2 } }
          ]
        }
      ]
    },

    // ===== TEST CASE 10 =====
    {
      "name": "Magnetism + Earth: metallic vs non-metallic entities with N-body gravity",
      "configurationFile": "NBodySetup.json",
      "description": "Two entities under N-body gravity: one metallic (affected by magnetic field), one non-metallic (gravity only)",
      "headerLines": [
        "TEST CASE 10: Magnetism + Earth - Metallic vs Non-Metallic",
        "Metal ball: N-body gravity + magnetic force (upward)",
        "Plastic ball: N-body gravity only"
      ],
      "steps": [
        {
          "step": 0,
          "actions": [
            { "type": "spawn", "entity": "Earth" },
            { "type": "spawn", "entity": "EarthSurface" },
            { "type": "spawn", "entity": "Ball_GravityDragMagnetism", "properties": { "Position": [-2, 6.37105e6, 0], "Color": "Silver", "Mass": 1.0, "Radius": 0.2 } },
            { "type": "spawn", "entity": "Ball_GravityDrag", "properties": { "Position": [2, 6.37105e6, 0], "Color": "Orange", "Mass": 1.0, "Radius": 0.2 } }
          ]
        }
      ]
    },

    // ===== TEST CASE 11 =====
    {
      "name": "Wind effect + Earth: large radius vs small radius with N-body gravity",
      "configurationFile": "NBodySetup.json",
      "description": "Two entities with same mass under N-body gravity: one with large radius (affected by wind), one with small radius (minimal wind effect)",
      "headerLines": [
        "TEST CASE 11: Wind Effect + Earth - Large vs Small Radius",
        "Large ball: N-body gravity + wind (large cross-section)",
        "Small ball: N-body gravity + minimal wind (small cross-section)"
      ],
      "steps": [
        {
          "step": 0,
          "actions": [
            { "type": "spawn", "entity": "Earth" },
            { "type": "spawn", "entity": "EarthSurface" },
            { "type": "spawn", "entity": "Ball_GravityDragWind", "properties": { "Position": [-2, 6.37105e6, 0], "Color": "DeepSkyBlue", "Mass": 1.0, "Radius": 1.0 } },
            { "type": "spawn", "entity": "Ball_GravityDragWind", "properties": { "Position": [2, 6.37105e6, 0], "Color": "Turquoise", "Mass": 1.0, "Radius": 0.5 } }
          ]
        }
      ]
    },

    // ===== TEST CASE 12 =====
    {
      "name": "Combined forces + Earth: gravity only, gravity+magnetism, gravity+wind, gravity+magnetism+wind with N-body",
      "configurationFile": "NBodySetup.json",
      "description": "Four entities with identical size/mass but different force combinations under N-body gravity: gravity-only, gravity+magnetism, gravity+wind, gravity+magnetism+wind",
      "headerLines": [
        "TEST CASE 12: Combined Forces + Earth - Force Composition with N-Body",
        "Entity 1: N-body gravity only (downward)",
        "Entity 2: N-body gravity + magnetism (upward magnetic force)",
        "Entity 3: N-body gravity + wind (horizontal wind push)",
        "Entity 4: N-body gravity + magnetism + wind (all forces)"
      ],
      "steps": [
        {
          "step": 0,
          "actions": [
            { "type": "spawn", "entity": "Earth" },
            { "type": "spawn", "entity": "EarthSurface" },
            { "type": "spawn", "entity": "Ball_GravityDrag", "properties": { "Position": [-4, 6.37105e6, 0], "Color": "Red", "Mass": 1.0, "Radius": 0.3 } },
            { "type": "spawn", "entity": "Ball_GravityDragMagnetism", "properties": { "Position": [-1, 6.37105e6, 0], "Color": "Gold", "Mass": 1.0, "Radius": 0.3 } },
            { "type": "spawn", "entity": "Ball_GravityDragWind", "properties": { "Position": [1, 6.37105e6, 0], "Color": "Cyan", "Mass": 1.0, "Radius": 0.3 } },
            { "type": "spawn", "entity": "Ball_GravityDragMagnetismWind", "properties": { "Position": [4, 6.37105e6, 0], "Color": "Lime", "Mass": 1.0, "Radius": 0.3 } }
          ]
        }
      ]
    },

    // ===== TEST CASE 13 =====
    {
      "name": "N-body gravity: late spawn",
      "configurationFile": "NBodySetup.json",
      "description": "N-body gravity only with one ball at start and a second ball spawned mid-simulation",
      "headerLines": [
        "TEST CASE 13: N-Body Gravity - Late Spawn",
        "Ball 1: spawned at step 0",
        "Ball 2: spawned at step 100"
      ],
      "steps": [
        {
          "step": 0,
          "actions": [
            { "type": "spawn", "entity": "Earth" },
            { "type": "spawn", "entity": "EarthSurface" },
            { "type": "spawn", "entity": "Ball_GravityDrag", "properties": { "Position": [-1, 6.37105e6, 0], "Color": "Red", "Mass": 1.0, "Radius": 0.2 } }
          ]
        },
        {
          "step": 100,
          "actions": [
            { "type": "spawn", "entity": "Ball_GravityDrag", "properties": { "Position": [1, 6.37105e6, 0], "Color": "Blue", "Mass": 1.0, "Radius": 0.25 } }
          ]
        }
      ]
    },

    // ===== TEST CASE 14 =====
    {
      "name": "Entity removal and name reuse",
      "configurationFile": "NBodySetup.json",
      "description": "Demonstrates entity removal freeing up names for reuse",
      "headerLines": [
        "TEST CASE 14: Entity Removal & Name Reuse",
        "Spawn Ball_GravityDrag, remove it, then spawn another Ball_GravityDrag",
        "Both use the same entity type name (not numbered)"
      ],
      "steps": [
        {
          "step": 0,
          "actions": [
            { "type": "spawn", "entity": "Ball_GravityDrag", "properties": { "Position": [0, 6.37105e6, 0], "Color": "Red", "Mass": 1.0, "Radius": 0.2 } },
            { "type": "spawn", "entity": "Earth" },
            { "type": "spawn", "entity": "EarthSurface" }
          ]
        },
        {
          "step": 100,
          "actions": [
            { "type": "remove", "entity": "Ball_GravityDrag", "properties": { "EntityId": 0 } }
          ]
        },
        {
          "step": 200,
          "actions": [
            { "type": "spawn", "entity": "Ball_GravityDrag", "properties": { "Position": [2, 6.37105e6, 0], "Color": "Red", "Mass": 1.0, "Radius": 0.3 } }
          ]
        }
      ]
    }
  ]
}
