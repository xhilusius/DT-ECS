{
  "name": "Default Gravity and Position Simulation",
  "description": "Simulation with parallel force composition: Force models run in parallel, PhysicsIntegrator sums forces",
  "timeStep": {
    "value": 10,
    "unit": "ms"
  },
  "parallel": true,
  "stepDelayMs": 10,
  "simulationSteps": 500,

  "simulationModels": [
    {
      "name": "GravityModel",
      "inputProperties": ["GravityForce","Mass"],
      "outputProperties": ["GravityForce"]
    },
    {
      "name": "DragModel",
      "inputProperties": ["CurrentSpeed", "Radius", "Mass"],
      "outputProperties": ["DragForce"]
    },
    {
      "name": "MagnetismModel",
      "inputProperties": ["MagnetismForce", "Mass"],
      "outputProperties": ["MagnetismForce"]
    },
    {
      "name": "WindForceModel",
      "inputProperties": ["WindForce", "Radius"],
      "outputProperties": ["WindForce"]
    },
    {
      "name": "PhysicsIntegrator",
      "inputProperties": ["Mass", "CurrentSpeed"],
      "optionalInputProperties": ["GravityForce", "DragForce", "MagnetismForce", "WindForce"],
      "outputProperties": ["CurrentSpeed", "Displacement"]
    },
    {
      "name": "PositionModel",
      "inputProperties": ["Position", "Displacement"],
      "outputProperties": ["Position", "Displacement"]
    }
  ],
  "executionBatches": [
    ["GravityModel", "DragModel", "MagnetismModel", "WindForceModel"],
    ["PhysicsIntegrator"],
    ["PositionModel"]
  ]
}

