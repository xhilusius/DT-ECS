{
  "name": "N-Body Gravity and Position Simulation",
  "description": "Simulation with parallel force composition: N-body gravity runs in parallel, PhysicsIntegrator sums forces",
  "timeStep": {
    "value": 100,
    "unit": "ms"
  },
  "parallel": true,
  "stepDelayMs": 20,
  "simulationSteps": 100,

  "simulationModels": [
    {
      "name": "NBodyGravityModel",
      "inputProperties": ["Mass", "Position", "GravityForce"],
      "outputProperties": ["GravityForce"]
    },
    {
      "name": "DragModel",
      "inputProperties": ["CurrentSpeed", "Radius", "Mass", "DragForce"],
      "outputProperties": ["DragForce"]
    },
    {
      "name": "MagnetismModel",
      "inputProperties": ["MagnetismForce", "Mass"],
      "outputProperties": ["MagnetismForce"]
    },
    {
      "name": "WindForceModel",
      "inputProperties": ["WindForce", "Radius"],
      "outputProperties": ["WindForce"]
    },
    {
      "name": "PhysicsIntegrator",
      "inputProperties": ["Mass", "CurrentSpeed"],
      "optionalInputProperties": ["GravityForce", "DragForce", "MagnetismForce", "WindForce"],
      "outputProperties": ["CurrentSpeed", "Displacement"]
    },
    {
      "name": "PositionModel",
      "inputProperties": ["Position", "Displacement"],
      "outputProperties": ["Position", "Displacement"]
    }
  ],
  "executionBatches": [
    ["NBodyGravityModel", "DragModel", "MagnetismModel", "WindForceModel"],
    ["PhysicsIntegrator"],
    ["PositionModel"]
  ]
}
